# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Explicitly declare text files
*.go text
*.md text
*.txt text
*.yaml text
*.yml text
*.json text
*.toml text
*.proto text
*.sh text
*.ps1 text

# Denote binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.flv binary
*.fla binary
*.swf binary
*.gz binary
*.zip binary
*.7z binary
*.ttf binary
*.eot binary
*.woff binary
*.woff2 binary
*.pyc binary
*.pdf binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary

# Go specific
*.sum linguist-generated=true
go.sum linguist-generated=true

# Documentation
*.md linguist-documentation

# Proto files
*.proto linguist-language=Protocol-Buffer
